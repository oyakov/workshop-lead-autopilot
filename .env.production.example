# ═══════════════════════════════════════════════════════════════════════════════
# .env.production.example
# Copy to .env on the production server and fill in all values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
AGENCY_NAME=Workshop
ENVIRONMENT=production

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX

ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Token for n8n → app webhooks. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_TOKEN=REPLACE_WITH_RANDOM_TOKEN

# ── CORS (lock to your domain in production!) ─────────────────────────────────
ALLOWED_ORIGINS=https://vestint.duckdns.org

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-lite

LLM_FALLBACK_PROVIDER=
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=google/gemma-3-4b

# ── CRM ───────────────────────────────────────────────────────────────────────
CRM_PROVIDER=hubspot
HUBSPOT_TOKEN=your-hubspot-private-app-token

# ── SMTP (required for real email sending) ────────────────────────────────────
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Workshop <your@gmail.com>

# ── IMAP (optional — intake from email inbox) ─────────────────────────────────
IMAP_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_SECONDS=60

# ── Outreach ──────────────────────────────────────────────────────────────────
CALENDAR_LINK=https://cal.com/yourname/15min
FOLLOWUP_AUTO_SEND=true
SLA_HOURS=24
FOLLOWUP_CLIENT_HOURS=48
FOLLOWUP_FINAL_HOURS=72

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_IDS=your-chat-id

# ── Owners ────────────────────────────────────────────────────────────────────
OWNERS=oleg@workshop.ai

# ── Scoring ───────────────────────────────────────────────────────────────────
SCORING_ENABLED=true
SCORE_HOT_THRESHOLD=70
SCORE_WARM_THRESHOLD=40

# ── n8n auth (for n8n UI) ─────────────────────────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_USER=admin
N8N_PASSWORD=REPLACE_WITH_STRONG_N8N_PASSWORD

# ── n8n → app connection ──────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=https://vestint.duckdns.org
N8N_USER=admin
N8N_PASSWORD=changeme
