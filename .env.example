# ═══════════════════════════════════════════════════════════════════
# Workshop Lead-to-CRM Autopilot — Environment Variables Reference
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════

# ── App Core ─────────────────────────────────────────────────────────────────
AGENCY_NAME=Workshop
ENVIRONMENT=development          # development | production
SECRET_KEY=change-me-to-random-64-char-string    # openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here
WEBHOOK_TOKEN=your-n8n-webhook-secret            # used by n8n workflows

# ── Supabase (leave empty to use in-memory fallback for local dev) ────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key              # NOT the anon key

# ── LLM — Primary ────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini              # gemini | lmstudio | openai
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-lite

# ── LLM — Fallback (optional, activated when primary fails) ──────────────────
LLM_FALLBACK_PROVIDER=           # gemini | lmstudio | openai | (empty = disabled)
LLM_BASE_URL=http://localhost:1234/v1    # LM Studio default
LLM_API_KEY=lm-studio
LLM_MODEL=google/gemma-3-4b

# ── CRM ──────────────────────────────────────────────────────────────────────
CRM_PROVIDER=hubspot             # hubspot | pipedrive | amocrm | none
HUBSPOT_TOKEN=your-hubspot-private-app-token     # scopes: crm.objects.*
PIPEDRIVE_API_KEY=
PIPEDRIVE_COMPANY_DOMAIN=
AMOCRM_SUBDOMAIN=
AMOCRM_TOKEN=

# ── Email Intake (IMAP — optional) ───────────────────────────────────────────
IMAP_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your@gmail.com
IMAP_PASSWORD=your-app-password   # Gmail: use App Password, not account password
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_SECONDS=60

# ── Email Sending (SMTP — optional, required for actual outreach) ─────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=Workshop <your@gmail.com>

# ── Follow-up Automation ─────────────────────────────────────────────────────
FOLLOWUP_AUTO_SEND=true          # true = auto-send; false = request human approval
SLA_HOURS=24                     # T+24h: owner reminder
FOLLOWUP_CLIENT_HOURS=48         # T+48h: first follow-up to client
FOLLOWUP_FINAL_HOURS=72          # T+72h: final follow-up to client

# ── Outreach ─────────────────────────────────────────────────────────────────
CALENDAR_LINK=https://cal.com/yourname/15min    # Inserted into all draft emails

# ── Telegram Alerts (optional) ───────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-bot-token               # from @BotFather
TELEGRAM_CHAT_IDS=123456789,987654321           # comma-separated chat IDs

# ── Lead Owners (round-robin assignment) ─────────────────────────────────────
OWNERS=owner1@company.com,owner2@company.com

# ── Scoring Thresholds ───────────────────────────────────────────────────────
SCORING_ENABLED=true
SCORE_HOT_THRESHOLD=70           # score >= 70 → hot
SCORE_WARM_THRESHOLD=40          # score >= 40 → warm; < 40 → cold (skip CRM)

# ── n8n Integration (optional) ───────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=http://n8n:5678
N8N_USER=admin
N8N_PASSWORD=changeme
