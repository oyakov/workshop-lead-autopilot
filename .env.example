# ============================================================
# Lead-to-CRM Autopilot — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- App ---
AGENCY_NAME=Workshop
ENVIRONMENT=development          # development | production
SECRET_KEY=change-me-in-production

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key    # service_role (server-side only)

# --- LLM Primary ---
# Options: gemini | lmstudio | openai
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash-lite

# --- LLM Fallback (leave empty to disable) ---
LLM_FALLBACK_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=google/gemma-3-4b

# --- CRM ---
# Options: hubspot | pipedrive | amocrm | none
CRM_PROVIDER=hubspot

# HubSpot
HUBSPOT_TOKEN=pat-na1-...

# Pipedrive (if CRM_PROVIDER=pipedrive)
PIPEDRIVE_API_KEY=
PIPEDRIVE_COMPANY_DOMAIN=yourcompany

# amoCRM (if CRM_PROVIDER=amocrm)
AMOCRM_SUBDOMAIN=yourcompany
AMOCRM_TOKEN=

# --- Email Intake (IMAP) ---
IMAP_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=leads@yourcompany.com
IMAP_PASSWORD=app-password
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL_SECONDS=60

# --- Email Sending (SMTP) ---
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=leads@yourcompany.com
SMTP_PASSWORD=app-password
SMTP_FROM=leads@yourcompany.com

# --- Follow-up ---
# Auto-send follow-ups without human approval
FOLLOWUP_AUTO_SEND=true
# Hours until first follow-up reminder to owner
SLA_HOURS=24
# Hours until second follow-up (client email)
FOLLOWUP_CLIENT_HOURS=48

# --- Telegram Alerts ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Comma-separated chat IDs for alerts
TELEGRAM_CHAT_IDS=-100123456789

# --- Owners (round-robin routing) ---
# Comma-separated email list
OWNERS=oleg@workshop.ai,boris@workshop.ai

# --- n8n ---
N8N_WEBHOOK_BASE_URL=http://n8n:5678
N8N_USER=admin
N8N_PASSWORD=changeme

# --- Scoring ---
SCORING_ENABLED=true
# Score thresholds: score >= HOT_THRESHOLD → hot, etc.
SCORE_HOT_THRESHOLD=70
SCORE_WARM_THRESHOLD=40
